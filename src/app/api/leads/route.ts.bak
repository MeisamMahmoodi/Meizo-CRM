import { NextResponse } from 'next/server'
import { getAllLeads, upsertLeads, addLead, addLeadsBulk } from '@/lib/db'

export async function GET(req: Request) {
  try {
    const { searchParams } = new URL(req.url)
    const assignedTo = searchParams.get('assignedTo') || undefined
    const leads = await getAllLeads(assignedTo)
    return NextResponse.json(leads)
  } catch (e: any) {
    return NextResponse.json({ error: e.message }, { status: 500 })
  }
}

export async function POST(req: Request) {
  try {
    const { searchParams } = new URL(req.url)
    const body = await req.json()
    if (Array.isArray(body)) {
      const replace = searchParams.get('replace') === 'true'
      if (replace) {
        const assignedTo = searchParams.get('assignedTo') || ''
        await upsertLeads(body, assignedTo)
      } else {
        await addLeadsBulk(body)
      }
      return NextResponse.json({ ok: true })
    }
    await addLead(body)
    return NextResponse.json({ ok: true })
  } catch (e: any) {
    return NextResponse.json({ error: e.message }, { status: 500 })
  }
}
